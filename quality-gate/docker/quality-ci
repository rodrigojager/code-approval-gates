#!/bin/sh
set -eu
set -f

# The GitLab-facing launcher is a trust boundary. Start the Python process with
# an empty environment and copy only the inputs that the governed CI contract
# needs. A POSIX shell is used so Bash startup hooks cannot run before env -i.
readonly QUALITY_CI_PYTHON="/opt/venvs/quality-sidecar/bin/python"
readonly QUALITY_CI_PATH_FILE="/etc/code-approval/quality-gate-path"
readonly QUALITY_CI_TRANSPORT_FILE="/etc/code-approval/quality-gate-transport.env"
readonly QUALITY_CI_HOME="/home/quality"
readonly QUALITY_CI_CACHE="/home/quality/.cache"

fail_configuration() {
  printf 'quality-ci: %s\n' "$1" >&2
  exit 3
}

if [ ! -r "$QUALITY_CI_PATH_FILE" ]; then
  fail_configuration "trusted PATH file is missing or unreadable"
fi
if [ ! -f "$QUALITY_CI_PATH_FILE" ] || [ -L "$QUALITY_CI_PATH_FILE" ]; then
  fail_configuration "trusted PATH file is non-regular or a symlink"
fi
[ "$(/bin/stat -c '%u:%g:%a' "$QUALITY_CI_PATH_FILE")" = "0:0:444" ] \
  || fail_configuration "trusted PATH file must be root:root mode 0444"

# Accept one non-empty line (plus its normal trailing newline) and reject any
# injected second line or carriage return. The file is baked root:root 0444.
exec 3< "$QUALITY_CI_PATH_FILE"
QUALITY_CI_PATH=
if ! IFS= read -r QUALITY_CI_PATH <&3 && [ -z "$QUALITY_CI_PATH" ]; then
  fail_configuration "trusted PATH file is empty"
fi
unexpected_line=
if IFS= read -r unexpected_line <&3 || [ -n "$unexpected_line" ]; then
  fail_configuration "trusted PATH file contains more than one line"
fi
exec 3<&-
carriage_return=$(printf '\r')
case "$QUALITY_CI_PATH" in
  ''|*"$carriage_return"*)
    fail_configuration "trusted PATH file is invalid"
    ;;
esac
readonly QUALITY_CI_PATH

validate_trusted_path_chain() {
  current_path=$1
  require_traverse=${2:-false}
  while [ "$current_path" != "/" ]; do
    owner=$(/bin/stat -c '%u:%g' "$current_path") || fail_configuration "cannot stat trusted path component"
    mode=$(/bin/stat -c '%a' "$current_path") || fail_configuration "cannot read trusted path permissions"
    [ "$owner" = "0:0" ] || fail_configuration "trusted path components must be owned by root:root"
    case "$mode" in
      [0-7][0145][0145]) ;;
      *) fail_configuration "trusted path components must not be group- or world-writable" ;;
    esac
    if [ "$require_traverse" = "true" ]; then
      case "$mode" in
        [0-7][0145][15]) ;;
        *) fail_configuration "trusted PATH components must be traversable by the quality user" ;;
      esac
    fi
    current_path=$(/usr/bin/dirname "$current_path")
  done
}

case "$QUALITY_CI_PATH" in
  :*|*::|*:)
    fail_configuration "trusted PATH contains an empty entry"
    ;;
esac
old_ifs=$IFS
IFS=:
for path_dir in $QUALITY_CI_PATH; do
  case "$path_dir" in
    /*) ;;
    *) fail_configuration "trusted PATH entries must be absolute" ;;
  esac
  case "$path_dir" in
    /root|/root/*) fail_configuration "trusted PATH must not traverse /root" ;;
  esac
  canonical_path_dir=$(/usr/bin/readlink -f "$path_dir") \
    || fail_configuration "trusted PATH entry does not resolve"
  [ "$canonical_path_dir" = "$path_dir" ] \
    || fail_configuration "trusted PATH entries must already be canonical"
  [ -d "$path_dir" ] || fail_configuration "trusted PATH entry is not a directory"
  [ -x "$path_dir" ] || fail_configuration "trusted PATH entry is not traversable"
  validate_trusted_path_chain "$path_dir" true
done
IFS=$old_ifs

validate_ca_setting() {
  ca_name=$1
  ca_path=$2
  [ -n "$ca_path" ] || fail_configuration "$ca_name cannot be empty"
  case "$ca_path" in
    /*) ;;
    *) fail_configuration "$ca_name must use an absolute path" ;;
  esac
  canonical_ca_path=$(/usr/bin/readlink -f "$ca_path") \
    || fail_configuration "$ca_name does not resolve to an existing path"
  case "$canonical_ca_path" in
    /etc/code-approval/ca/*|/etc/ssl/*|/usr/local/share/ca-certificates/*) ;;
    *) fail_configuration "$ca_name must resolve below a trusted system CA directory" ;;
  esac
  if [ "$ca_name" = "SSL_CERT_DIR" ]; then
    [ -d "$canonical_ca_path" ] || fail_configuration "$ca_name must resolve to a directory"
  else
    [ -f "$canonical_ca_path" ] || fail_configuration "$ca_name must resolve to a regular file"
  fi
  [ -r "$canonical_ca_path" ] || fail_configuration "$ca_name is not readable by the quality user"
  validate_trusted_path_chain "$canonical_ca_path"
}

# Preserve the original CLI arguments behind the trusted executable. Every
# accepted environment entry is then prepended as one opaque argv element, so
# whitespace, equals signs, and newlines in values are never evaluated.
set -- "$QUALITY_CI_PYTHON" -m quality_sidecar.ci "$@"
while IFS= read -r -d '' entry; do
  name=${entry%%=*}
  case "$name" in
    CI_COMMIT_SHA|CI_MERGE_REQUEST_TARGET_BRANCH_NAME|\
    CODE_APPROVAL_QUALITY_TARGET_BRANCH|\
    CODE_APPROVAL_QUALITY_POLICY_FILE|CODE_APPROVAL_QUALITY_POLICY_SHA256|\
    CODE_APPROVAL_QUALITY_LOCALE)
      set -- "$entry" "$@"
      ;;
  esac
done < /proc/self/environ

# Network transport settings come only from a runner-mounted, root-owned,
# read-only file. Merge Request variables cannot replace scanner feeds or TLS
# trust. Format: one allowlisted NAME=value per line, with optional # comments.
if [ ! -f "$QUALITY_CI_TRANSPORT_FILE" ] || [ -L "$QUALITY_CI_TRANSPORT_FILE" ]; then
  fail_configuration "trusted transport file is missing, non-regular, or a symlink"
fi
transport_owner=$(/bin/stat -c '%u:%g' "$QUALITY_CI_TRANSPORT_FILE") \
  || fail_configuration "cannot stat trusted transport file"
transport_mode=$(/bin/stat -c '%a' "$QUALITY_CI_TRANSPORT_FILE") \
  || fail_configuration "cannot read trusted transport permissions"
[ "$transport_owner" = "0:0" ] || fail_configuration "trusted transport file must be owned by root:root"
case "$transport_mode" in
  444) ;;
  *) fail_configuration "trusted transport file mode must be 0444" ;;
esac
validate_trusted_path_chain "$QUALITY_CI_TRANSPORT_FILE"

seen_transport_names=:
while IFS= read -r transport_line || [ -n "$transport_line" ]; do
  case "$transport_line" in
    ''|'#'*) continue ;;
    *"$carriage_return"*) fail_configuration "trusted transport file contains a carriage return" ;;
    *=*) ;;
    *) fail_configuration "trusted transport entry must use NAME=value" ;;
  esac
  transport_name=${transport_line%%=*}
  transport_value=${transport_line#*=}
  case "$seen_transport_names" in
    *:"$transport_name":*) fail_configuration "duplicate trusted transport entry: $transport_name" ;;
  esac
  case "$transport_name" in
    HTTP_PROXY|HTTPS_PROXY|ALL_PROXY|NO_PROXY|\
    http_proxy|https_proxy|all_proxy|no_proxy)
      [ -n "$transport_value" ] || fail_configuration "$transport_name cannot be empty"
      case "$transport_name" in
        NO_PROXY|no_proxy) ;;
        *)
          case "$transport_value" in
            http://*|https://*|socks5://*|socks5h://*) ;;
            *) fail_configuration "$transport_name must use an allowlisted proxy URL scheme" ;;
          esac
          case "$transport_value" in
            *://*@*) fail_configuration "$transport_name must not contain proxy credentials" ;;
          esac
          ;;
      esac
      ;;
    SSL_CERT_FILE|SSL_CERT_DIR|REQUESTS_CA_BUNDLE|CURL_CA_BUNDLE|\
    NODE_EXTRA_CA_CERTS|GIT_SSL_CAINFO)
      validate_ca_setting "$transport_name" "$transport_value"
      ;;
    *) fail_configuration "unsupported trusted transport entry: $transport_name" ;;
  esac
  seen_transport_names="${seen_transport_names}${transport_name}:"
  set -- "$transport_line" "$@"
done < "$QUALITY_CI_TRANSPORT_FILE"

# Fixed runtime values are not copied from the GitLab job. Interpreter and
# loader hooks, generic CI secrets, Git credential helpers, PATH, and HOME are
# consequently absent from the child process.
set -- \
  "PATH=$QUALITY_CI_PATH" \
  "HOME=$QUALITY_CI_HOME" \
  "XDG_CACHE_HOME=$QUALITY_CI_CACHE" \
  "LANG=C.UTF-8" \
  "LC_ALL=C.UTF-8" \
  "PYTHONNOUSERSITE=1" \
  "PYTHONSAFEPATH=1" \
  "$@"

exec /usr/bin/env -i "$@"
