{
  "name": "semantic-gate",
  "version": "0.1.0",
  "description": "AI-powered semantic quality gate for reviewing recent code changes before deterministic quality-check.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "semantic-gate": "dist/cli.js"
  },
  "files": [
    "dist/",
    "templates/",
    "examples/",
    "schemas/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "npm run build && node --test tests/*.test.js",
    "test:unit": "node --test tests/*.test.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=18.17"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
